<%layout("/layouts/boilerplate")%>

<div class="row mt-3">
    <h1 class="col-6 offset-2">SignUp on WanderLust</h1>
    <div class="col-8 offset-2">
        <form action="/signup" method="POST" class="needs-validation" novalidate >
            <div class="mb-3">
                <label for="username" class="form-label">UserName</label>
                <input  name="username" id="username" type="text" placeholder="UserName" class="form-control" required>
                <div class="valid-feedback">Looks good !</div>
            </div>
            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <input  name="email" id="email" type="email" placeholder="@gmail.com" class="form-control" required>
            </div>
            <div class="mb-3">
                <label for="password" class="form-label">PassWord</label>
                <input  name="password" id="password" type="password" placeholder="Enter Password" class="form-control" required>
            </div>
            <button class="btn btn-success">SignUp</button>
        </form>
    </div>
</div>