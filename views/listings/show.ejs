<% layout("/layouts/boilerplate")-%>
    <div class="row">
        <h3 class="offset-2"><%=listing.title%></h3>
    <div class="col-8 offset-2">  
    
        <div class="card col-8 offset-2">
        <img src="<%=listing.image.url%>" class="card-img-top show-img" alt="Listing Image">
        </div>
    </div>
    <div class="card-body">
        <p class="card-text offset-2 ">
                <%=listing.description%><br>
                $<%=listing.price.toLocaleString("en-US")%><br>
                <%=listing.location%><br>
                <%=listing.country%>
        </p>
    </div>


    <div class="btns mt-3 mb-3 gap-3 offset-3">
    <a href="/listings/<%=listing._id%>/edit" class="btn btn-dark add-btn">Edit</a>
    <form method="POST" action="/listings/<%=listing._id%>/?_method=DELETE" >
        <button class="btn btn-dark ">Delete</button>
    </form>
    </div>
    
