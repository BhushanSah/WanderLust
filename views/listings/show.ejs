<% layout("/layouts/boilerplate")-%>
<script>
    const mapToken="<%=MAP_TOKEN%>";
    const coordinates=<%-JSON.stringify(listing.geometry.coordinates)%>;
</script>
    <div class="row">
        <h3 class="offset-2"><%=listing.title%></h3>
    <div class="col-8 offset-2">  
    
        <div class="card col-8 offset-2">
        <img src="<%=listing.image.url%>" class="card-img-top show-img" alt="Listing Image">
        </div>
    </div>
    <div class="card-body">
        <p class="card-text offset-2 ">Owned by:<i><b> <%=listing.owner.username%></b></i></p>
        <p class="card-text offset-2 "><%=listing.description%></p>        
        <p class="card-text offset-2 ">$<%=listing.price.toLocaleString("en-US")%></p>       
        <p class="card-text offset-2 "><%=listing.location%></p>
        <p class="card-text offset-2 "><%=listing.country%></p>  
    </div>

    <% if(currUser && currUser._id.equals(listing.owner._id)) {%>
    <div class="btns mt-3 mb-3 gap-3 offset-3">
    <a href="/listings/<%=listing._id%>/edit" class="btn btn-dark add-btn">Edit</a>
    <form method="POST" action="/listings/<%=listing._id%>/?_method=DELETE" >
        <button class="btn btn-dark ">Delete</button>
    </form>
    </div>
    <%}%>
    <hr>
    <div class="offset-2">
        <%if(currUser) {%>
        <h4>Leave a Review</h4>
        <form action="/listings/<%=listing._id%>/reviews" method="POST" novalidate class="needs-validation">
            <label for="rating" class="form-label"><h5>Rating</h5></label>
            <fieldset class="starability-slot">
            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
            <label for="first-rate1" title="Terrible">1 star</label>
            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
            <label for="first-rate2" title="Not good">2 stars</label>
            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
            <label for="first-rate3" title="Average">3 stars</label>
            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
            <label for="first-rate4" title="Very good">4 stars</label>
            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
            <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
            <div>
                <label for="comment" class="form-label">Comments</label>
                <textarea name="review[comment]" id="comment" cols="30" rows="3" class="form-control" style="width: 30rem;" required></textarea>
            </div>
            <br>
            <button class="btn btn-outline-dark submit-btn mb-3">Submit</button>
            <hr>
            <%}%>
        </form>
        
        <% if(listing.reviews.length>0) {%>
        <div class="row">
            <h4>All Reviews</h4>
        <% for (review of listing.reviews){%>
            <div class="card col-5 mb-3 ms-2">
                <div class="card-title"><b>@<%=review.author.username%></b></div>
                <p class="starability-result" data-rating="<%=review.rating%>"></p>
                <p class="card-text"><%=review.comment%></p>
                <form method="POST" action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE" >
                    <% if(currUser && currUser._id.equals(review.author._id)) {%>
                    <button class="btn btn-sm btn-dark mb-1">Delete</button>
                    <%}%>
                </form>
            </div>
        <%}%>
        </div>
        <%}%>
    </div>
    <div class="col-6 offset-2 mb-3">
        <h3>Where you'll be</h3>
        <div id="map"></div>
    </div>
<script src="/js/map.js"> </script>

    
